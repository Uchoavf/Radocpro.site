# Chave da API de IA (server-side — NUNCA use NEXT_PUBLIC_ aqui)
# A API Route /api/ai faz o proxy sem expor a chave ao navegador
ANTHROPIC_API_KEY=your_api_key_here

# URL pública do app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Banco de dados (futuro)
DATABASE_URL=postgresql://user:password@localhost:5432/radoc_service

# Autenticação (futuro)
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Stripe (futuro — publishable key é pública por natureza)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
